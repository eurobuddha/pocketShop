{
  "name": "minifshop",
  "version": "1.0.0",
  "description": "Lightweight MiniDapp shop template for selling products on the Minima blockchain. Includes a shop, vendor inbox, and Studio web UI builder.",
  "main": "studio.js",
  "bin": {
    "minifshop": "studio.js"
  },
  "scripts": {
    "studio": "node studio.js",
    "build": "node build-miniFShop.js",
    "build:mac": "bash build/build-mac.sh",
    "build:win": "bash build/build-win.sh"
  },
  "pkg": {
    "scripts": [
      "studio.js",
      "studio-builder.js"
    ],
    "assets": [
      "web/**/*",
      "miniFShop-shop/**/*",
      "mInbox/**/*"
    ],
    "outputPath": "release"
  },
  "keywords": [
    "minima",
    "minidapp",
    "blockchain",
    "shop",
    "mds",
    "web3"
  ],
  "author": "eurobuddha",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eurobuddha/miniFShop.git"
  },
  "homepage": "https://github.com/eurobuddha/miniFShop",
  "files": [
    "studio.js",
    "studio-builder.js",
    "build-miniFShop.js",
    "web/",
    "mInbox/",
    "miniFShop-shop/",
    "build/"
  ],
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "archiver": "^7.0.1"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.1"
  }
}
